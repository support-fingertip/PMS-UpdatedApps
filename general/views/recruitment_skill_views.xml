<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_recruitment_skill_list" model="ir.ui.view">
        <field name="name">recruitment.skill.list</field>
        <field name="model">recruitment.skill</field>
        <field name="arch" type="xml">
            <list string="Skills" editable="bottom">
                <field name="name"/>
                <field name="color" widget="color_picker"/>
            </list>
        </field>
    </record>

    <record id="action_recruitment_skill" model="ir.actions.act_window">
        <field name="name">Skills</field>
        <field name="res_model">recruitment.skill</field>
        <field name="view_mode">list</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create your first skill tag</p>
            <p>Skill tags are shared between candidates and job positions.</p>
        </field>
    </record>

</odoo>
