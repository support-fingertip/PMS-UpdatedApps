<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_asset_maintenance_list" model="ir.ui.view">
        <field name="name">asset.maintenance.list</field>
        <field name="model">asset.maintenance</field>
        <field name="arch" type="xml">
            <list string="Maintenance"
                  decoration-warning="status=='in_progress'"
                  decoration-success="status=='completed'"
                  decoration-muted="status=='cancelled'">
                <field name="asset"/>
                <field name="issue_date"/>
                <field name="issue_description"/>
                <field name="service_vendor"/>
                <field name="repair_cost"/>
                <field name="status" widget="badge"/>
                <field name="completion_date"/>
            </list>
        </field>
    </record>

    <record id="view_asset_maintenance_form" model="ir.ui.view">
        <field name="name">asset.maintenance.form</field>
        <field name="model">asset.maintenance</field>
        <field name="arch" type="xml">
            <form string="Maintenance">
                <sheet>
                    <group>
                        <group>
                            <field name="asset"/>
                            <field name="issue_date"/>
                            <field name="issue_reported_by"/>
                            <field name="status"/>
                        </group>
                        <group>
                            <field name="service_vendor"/>
                            <field name="repair_cost"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="completion_date"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Issue Description" name="issue">
                            <field name="issue_description"/>
                        </page>
                        <page string="Attachments" name="attach">
                            <field name="attachment_ids" widget="many2many_binary"/>
                        </page>
                        <page string="Remarks" name="remarks">
                            <field name="remarks"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_asset_maintenance" model="ir.actions.act_window">
        <field name="name">Asset Maintenance</field>
        <field name="res_model">asset.maintenance</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>