<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_expense_dashboard_form" model="ir.ui.view">
        <field name="name">expense.dashboard.form</field>
        <field name="model">board.board</field>
        <field name="arch" type="xml">
            <form string="Expense Dashboard">
                <board style="2-1">
                    <column>
                        <action name="%(action_expense_monthly_report)d"
                                string="Expense by Month"
                                view_mode="graph"/>
                        <action name="%(action_expense_project_report)d"
                                string="Project / Client Cost"
                                view_mode="graph"/>
                    </column>
                    <column>
                        <action name="%(action_expense_pending_report)d"
                                string="Pending Approval"
                                view_mode="list"/>
                        <action name="%(action_advance_settlement_report)d"
                                string="Advance Settlement"
                                view_mode="list"/>
                    </column>
                </board>
            </form>
        </field>
    </record>

    <record id="action_expense_dashboard" model="ir.actions.act_window">
        <field name="name">Expense Dashboard</field>
        <field name="res_model">board.board</field>
        <field name="view_mode">form</field>
        <field name="usage">menu</field>
        <field name="view_id" ref="view_expense_dashboard_form"/>
    </record>

    <menuitem id="menu_expense_dashboard"
              name="Dashboard"
              parent="menu_expense_management_root"
              action="action_expense_dashboard"
              sequence="5"/>

</odoo>
