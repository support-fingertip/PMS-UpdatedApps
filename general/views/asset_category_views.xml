<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_asset_category_list" model="ir.ui.view">
        <field name="name">asset.category.list</field>
        <field name="model">asset.category</field>
        <field name="arch" type="xml">
            <list string="Asset Categories">
                <field name="category_name"/>
                <field name="asset_code_prefix"/>
                <field name="depreciation_applicable"/>
                <field name="useful_life_in_months"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="view_asset_category_form" model="ir.ui.view">
        <field name="name">asset.category.form</field>
        <field name="model">asset.category</field>
        <field name="arch" type="xml">
            <form string="Asset Category">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="category_name" placeholder="e.g. Laptop"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="asset_code_prefix" placeholder="e.g. LAP"/>
                            <field name="depreciation_applicable"/>
                            <field name="useful_life_in_months"/>
                        </group>
                        <group>
                            <field name="active" invisible="1"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description" name="description">
                            <field name="description"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_asset_category" model="ir.actions.act_window">
        <field name="name">Asset Categories</field>
        <field name="res_model">asset.category</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first asset category
            </p>
            <p>Group similar assets like laptops, phones or monitors.</p>
        </field>
    </record>

</odoo>
