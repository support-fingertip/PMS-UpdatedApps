<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Dashboard form view (board.board) for Asset Management -->
    <record id="view_asset_dashboard_form" model="ir.ui.view">
        <field name="name">asset.dashboard.form</field>
        <field name="model">board.board</field>
        <field name="arch" type="xml">
            <form string="Asset Dashboard">
                <board style="2-1">
                    <column>
                        <action name="%(action_asset_register_report)d"
                                string="Assets by Category"
                                view_mode="graph"/>
                        <action name="%(action_asset_maintenance_report)d"
                                string="Repair Cost by Month"
                                view_mode="graph"/>
                    </column>
                    <column>
                        <action name="%(action_asset_warranty_report)d"
                                string="Warranty Expiry"
                                view_mode="list"/>
                    </column>
                </board>
            </form>
        </field>
    </record>

    <record id="action_asset_dashboard" model="ir.actions.act_window">
        <field name="name">Asset Dashboard</field>
        <field name="res_model">board.board</field>
        <field name="view_mode">form</field>
        <field name="usage">menu</field>
        <field name="view_id" ref="view_asset_dashboard_form"/>
    </record>

    <menuitem id="menu_asset_dashboard"
              name="Dashboard"
              parent="menu_asset_management_root"
              action="action_asset_dashboard"
              sequence="5"/>

</odoo>
