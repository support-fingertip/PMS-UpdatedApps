<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_recruitment_offer_list" model="ir.ui.view">
        <field name="name">recruitment.offer.list</field>
        <field name="model">recruitment.offer</field>
        <field name="arch" type="xml">
            <list string="Offers"
                  decoration-info="offer_status=='sent'"
                  decoration-success="offer_status=='accepted'"
                  decoration-danger="offer_status=='rejected'"
                  decoration-muted="offer_status in ('draft','withdrawn')">
                <field name="candidate"/>
                <field name="job_position"/>
                <field name="offered_ctc"/>
                <field name="currency_id" invisible="1"/>
                <field name="offer_date"/>
                <field name="expected_joining_date"/>
                <field name="offer_status" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_recruitment_offer_form" model="ir.ui.view">
        <field name="name">recruitment.offer.form</field>
        <field name="model">recruitment.offer</field>
        <field name="arch" type="xml">
            <form string="Offer">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="candidate"/>
                            <field name="job_position"/>
                            <field name="offer_date"/>
                            <field name="expected_joining_date"/>
                            <field name="offer_status"/>
                        </group>
                        <group>
                            <field name="offered_ctc"/>
                            <field name="joining_bonus"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Offer Letter" name="letter">
                            <field name="offer_letter_attachment" widget="many2many_binary"/>
                        </page>
                        <page string="Remarks" name="remarks">
                            <field name="remarks"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_recruitment_offer" model="ir.actions.act_window">
        <field name="name">Offers</field>
        <field name="res_model">recruitment.offer</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>