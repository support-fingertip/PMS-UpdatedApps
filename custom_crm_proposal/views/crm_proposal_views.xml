<odoo>
<record id="view_crm_proposal_form" model="ir.ui.view">
    <field name="name">crm.proposal.form</field>
    <field name="model">crm.proposal</field>
    <field name="arch" type="xml">
        <form edit="state == 'draft'">
            <header>
                <button name="action_confirm" 
                        string="Confirm" 
                        type="object" 
                        class="oe_highlight" 
                        invisible="state != 'draft'"/>
                    <!-- Print button for full page view -->
                    <button name="%(action_report_crm_proposal)d" 
                            string="Print PDF" 
                            type="action" 
                            class="oe_highlight" 
                            invisible="state == 'draft'"/>
                    
                    <button name="action_copy_proposal" string="Duplicate Proposal" type="object" 
                            class="btn-primary" invisible="state == 'draft'"/>
                    
                    <field name="state" widget="statusbar"/>
                </header>
            <sheet>
                <div class="oe_title">
                    <h1><field name="name" readonly="1"/></h1>
                </div>
                <group>
                    <group>
                        <field name="opportunity_id" readonly="1" options="{'no_open': True}"/>
                    </group>
                    <group>
                        <field name="date_proposal" 
                            readonly="state == 'confirmed'" 
                            options="{'datepicker': {'minDate': 'today'}}"/>
                    </group>
                </group>

                <!-- Applying vertical="1" with additional classes for Odoo 18 -->
                <notebook vertical="1" class="o_vertical_tabs">

                    <page string="Executive Summary" name="executive_summary">
                        <field name="executive_summary" 
                            widget="html" 
                            readonly="state == 'confirmed'"
                            options="{'style-inline': true, 'resizable': true}"/>
                    </page>

                    <page string="Project Overview" name="project_overview">
                        <field name="project_overview" widget="html" readonly="state == 'confirmed'"/>
                    </page>

                    <page string="Scope of Work" name="scope_work">
                        <field name="scope_of_work" 
                            widget="html" 
                            readonly="state == 'confirmed'"
                            options="{'style-inline': true, 'resizable': true}"/>
                    </page>

                    <page string="Exclusions" name="exclusions">
                        <field name="exclusions" widget="html" readonly="state == 'confirmed'"/>
                    </page>

                    <page string="Project Deliverables" name="project_deliverables">
                        <field name="project_deliverables" widget="html" readonly="state == 'confirmed'"/>
                    </page>

                    <page string="Commercials" name="commercials">
                        <field name="cost_timeline_ids" readonly="state == 'confirmed'">
                            <list editable="bottom">
                                <field name="release" string="Module"/>
                                <field name="duration" string="Timeline"/>
                                <field name="cost" string="Cost (₹)" sum="PROJECT TOTAL"/>
                            </list>
                        </field>
                        <div class="mt-2">
                            <field name="gst_note" class="text-muted fw-bold"/>
                        </div>
                    </page>

                    <page string="Payment Milestones" name="payment_milestones">
                        <field name="milestone_ids" readonly="state == 'confirmed'">
                            <list editable="bottom" class="o_main_table">
                                <!-- Milestone Name: Takes up more space -->
                                <field name="milestone_text" string="Milestone" 
                                    placeholder="e.g. Project Kickoff"/>
                    
                                <!-- Amount: Right-aligned with currency widget -->
                                <field name="amount" string="Amount (₹)" sum="Total Amount"
                                    options="{'currency_field': 'currency_id'}"/>
                                
                                <!-- Percentage: Centered with a fixed width -->
                                <field name="percentage" string="Percentage (%)" 
                                    decoration-bf="1"/>
                            </list>
                        </field>
                    </page>

                    <page string="Project Timeline Production" name="project_timeline">
                        <!-- <p class="text-muted mb-2">Define project deployment schedule details below:</p> -->
                        <field name="project_timeline_production" widget="html" placeholder="Describe go-live preparation, staging, and hypercare schedule timelines..." readonly="state == 'confirmed'"/>
                    </page>

                    <page string="Dependencies from Client" name="dependencies_client">
                        <field name="dependencies_client" widget="html" readonly="state == 'confirmed'"/>
                    </page>

                    <page string="Terms &amp; Conditions" name="terms_conditions">
                        <field name="terms_conditions" 
                               widget="html" 
                               readonly="state == 'confirmed'"
                               options="{'style-inline': true}"/>
                    </page>

                    <page string="Approval &amp; Sign-off" name="approval">
                        <field name="approval_block" widget="html" readonly="state == 'confirmed'" options="{'style-inline': true}"/>
                    </page>
                        </notebook>
            </sheet>
      <!-- Footer remains for the initial 'New' popup -->
                <footer>
                    <!-- Save button: Allows editing and keeps the form open if in Draft -->
                    <button string="Save" 
                            special="save" 
                            class="btn-primary" 
                            invisible="state == 'confirmed'"/>
                    
                    <!-- Primary button to confirm and redirect -->
                    <!-- <button name="action_confirm" 
                            string="Confirm" 
                            type="object" 
                            class="btn-primary" 
                            invisible="state == 'confirmed'"/> -->
                    
                    <!-- Secondary button to cancel the creation -->
                    <button string="Discard" 
                            class="btn-secondary" 
                            special="cancel" 
                            invisible="state == 'confirmed'"/>
                    
                    
                </footer>
            
        </form>
    </field>
</record>

<record id="view_crm_proposal_tree" model="ir.ui.view">
        <field name="name">crm.proposal.list</field>
        <field name="model">crm.proposal</field>
        <field name="arch" type="xml">
            <list string="Proposals" default_order="name desc" class="o_main_table" create="false">
                <field name="name" string="Proposal Reference" decoration-bf="1"/>
                <field name="opportunity_id" string="Opportunity"/>
                <field name="date_proposal" string="Proposal Date"/>
                
                <field name="state" string="Status" 
                       widget="badge" 
                       decoration-info="state == 'draft'" 
                       decoration-success="state == 'confirmed'"/>
            </list>
        </field>
    </record>

    <record id="action_crm_proposal_all" model="ir.actions.act_window">
        <field name="name">Proposals</field>
        <field name="res_model">crm.proposal</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'create': False, 'edit': True}</field>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('view_crm_proposal_tree')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('view_crm_proposal_form')})
        ]"/> 
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create your first client proposal!</p>
        </field>
    </record>

    <menuitem id="menu_crm_proposal_root"
              name="Proposals"
              parent="crm.crm_menu_root"
              action="action_crm_proposal_all"
              sequence="15"/>

</odoo>