<odoo>
    <template id="report_proposal_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page" style="counter-reset: proposal-section; font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; color: #333333; font-size: 13px;">
                        
                        <style>
                            /* Professional Document Type Styles */
                            h2.proposal-title {
                                color: #005580;
                                font-weight: bold;
                                border-bottom: 2px solid #005580;
                                padding-bottom: 10px;
                            }
                            
                            h4.dynamic-section {
                                border-bottom: 1px solid #005580; 
                                padding-bottom: 6px; 
                                font-weight: bold;
                                color: #005580;
                                margin-top: 30px;
                                margin-bottom: 15px;
                                page-break-after: avoid;
                            }

                            /* Crash-Proof CSS Counter Engine for Dynamic Section Ordering */
                            h4.dynamic-section::before {
                                counter-increment: proposal-section;
                                content: counter(proposal-section) ". ";
                            }

                            /* Nested Sub-Headings (e.g., 1.1 About Fingertip, 1.2 Terminology) */
                            .content-block-wrapper h2, 
                            .page h2 {
                                font-size: 16px !important;       /* Slightly smaller than main headers */
                                font-weight: 600 !important;      /* Medium-bold weighting */
                                color: #2c3e50 !important;        /* Slate charcoal for clean sub-hierarchy */
                                margin-top: 15px;
                                margin-bottom: 8px;
                                padding-bottom: 0px;
                                border-bottom: none !important;   /* Keeps it looking clean without too many lines */
                                page-break-after: avoid;
                            }

                            /* Table  Typographic Formatting Polish */
                            .table-professional {
                                width: 100% !important;
                                table-layout: fixed;
                                border-collapse: collapse !important;
                                margin-bottom: 20px;
                            }
                            .table-professional th {
                                background-color: #005580 !important;
                                color: #ffffff !important;
                                font-weight: bold;
                                text-align: center;
                                vertical-align: middle;
                                padding: 10px 8px !important;
                                border: 1px solid #dee2e6 !important;
                            }

                            .table-professional td {
                                padding: 8px !important;
                                border: 1px solid #dee2e6 !important;
                                vertical-align: middle;
                            }
                            .zebra-striped-rows tr:nth-of-type(even) {
                                background-color: #f9f9f9 !important;
                            }
                            .content-block-wrapper {
                                line-height: 1.6;
                                text-align: justify;
                            }
                        </style>

                        <div class="row mt-2 mb-4">
                            <div class="col-12">
                                <h2 class="proposal-title">Proposal: <span t-field="doc.name"/></h2>
                            </div>
                        </div>
                        
                        <div class="row mb-4 bg-light p-3 rounded" style="border: 1px solid #dee2e6; margin-left: 0; margin-right: 0;">
                            <div class="col-6">
                                <strong style="color: #005580;">Proposal Date:</strong> 
                                <span t-field="doc.date_proposal" t-options='{"widget": "date"}'/>
                            </div>
                            <div class="col-6">
                                <strong style="color: #005580;">Opportunity Link:</strong> 
                                <span t-field="doc.opportunity_id.name"/>
                            </div>
                        </div>

                        <t t-if="doc.executive_summary">
                            <div class="mt-3 content-block-wrapper">
                                <h4 class="dynamic-section">Executive Summary</h4>
                                <div><t t-out="doc.executive_summary"/></div>
                            </div>
                        </t>

                        <t t-if="doc.project_overview">
                            <div class="mt-3 content-block-wrapper">
                                <h4 class="dynamic-section">Project Overview - RTT</h4>
                                <div><t t-out="doc.project_overview"/></div>
                            </div>
                        </t>

                        <t t-if="doc.scope_of_work">
                            <div class="mt-3 content-block-wrapper">
                                <h4 class="dynamic-section">Scope of Work</h4>
                                <div><t t-out="doc.scope_of_work"/></div>
                            </div>
                        </t>

                        <t t-if="doc.exclusions">
                            <div class="mt-3 content-block-wrapper">
                                <h4 class="dynamic-section">Exclusions</h4>
                                <div><t t-out="doc.exclusions"/></div>
                            </div>
                        </t>

                        <t t-if="doc.project_deliverables">
                            <div class="mt-3 content-block-wrapper">
                                <h4 class="dynamic-section">Project Deliverables - RTT</h4>
                                <div><t t-out="doc.project_deliverables"/></div>
                            </div>
                        </t>

                        <t t-if="doc.cost_timeline_ids">
                            <div class="mt-3 content-block-wrapper" style="page-break-inside: avoid;">
                                <h4 class="dynamic-section">Commercials</h4>
                                <table class="table table-sm table-bordered table-professional zebra-striped-rows mt-2">
                                    <thead>
                                        <tr>
                                            <th style="width: 40%;">Release</th>
                                            <th style="width: 30%;">Duration</th>
                                            <th style="width: 30%;">Cost</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr t-foreach="doc.cost_timeline_ids" t-as="line">
                                            <td><span t-field="line.release"/></td>
                                            <td class="text-center"><span t-field="line.duration"/></td>
                                            <td class="text-end" style="font-weight: bold;">
                                                <span t-field="line.cost" t-options='{"widget": "monetary", "display_currency": res_company.currency_id}'/>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                                <p t-if="doc.gst_note" class="mt-2 text-muted italic" style="font-size: 12px; font-style: italic;">
                                    <strong>Note:</strong> <span t-field="doc.gst_note"/>
                                </p>
                            </div>
                        </t>

                        <t t-if="doc.milestone_ids">
                            <div class="mt-3 content-block-wrapper" style="page-break-inside: avoid;">
                                <h4 class="dynamic-section">Payment Milestones</h4>
                                <table class="table table-sm table-bordered table-professional zebra-striped-rows mt-2">
                                    <thead>
                                        <tr>
                                            <th style="width: 40%;">Milestone</th>
                                            <th style="width: 30%;">Percentage (%)</th>
                                            <th style="width: 30%;">Amount</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr t-foreach="doc.milestone_ids" t-as="ms">
                                            <td><span t-field="ms.milestone_text"/></td>
                                            <td class="text-center" style="font-weight: bold;"><span t-field="ms.percentage"/>%</td>
                                            <td class="text-end" style="font-weight: bold;">
                                                <span t-field="ms.amount" t-options='{"widget": "monetary", "display_currency": res_company.currency_id}'/>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </t>

                        <t t-if="doc.project_timeline_production">
                            <div class="mt-3 content-block-wrapper">
                                <h4 class="dynamic-section">Project Timeline Production RTT</h4>
                                <div><t t-out="doc.project_timeline_production"/></div>
                            </div>
                        </t>

                        <t t-if="doc.dependencies_client">
                            <div class="mt-3 content-block-wrapper">
                                <h4 class="dynamic-section">Dependencies from Client</h4>
                                <div><t t-out="doc.dependencies_client"/></div>
                            </div>
                        </t>

                        <!-- <t t-if="doc.terms_conditions">
                            <div class="mt-3 content-block-wrapper" style="page-break-inside: avoid;">
                                <h4 class="dynamic-section" style="border-bottom: 1px solid #005580;">Terms and Conditions</h4>
                                <div style="font-size: 12px; color: #444444;"><t t-out="doc.terms_conditions"/></div>
                            </div>
                        </t> -->

                        <t t-if="doc.terms_conditions">
                            <div class="mt-4" style="page-break-inside: avoid;">
                                <h4 class="dynamic-section" style="border-bottom: 1px solid #005580; padding-bottom: 5px; font-weight: bold; color: #005580;">Terms and Conditions</h4>
                                
                                <div class="terms-nested-container" style="font-size: 12px; color: #444444;">
                                    <style>
                                        /* Tell the container to inherit the parent section counter number and reset the sub-counter */
                                        .terms-nested-container {
                                            counter-reset: terms-sub-section;
                                        }
                                        
                                        /* Target the bold prefix blocks inside the paragraphs */
                                        .terms-nested-container p strong.sub-clause::before {
                                            counter-increment: terms-sub-section;
                                            /* Compiles parent counter + dot + sub counter dynamically (e.g., "9.1 ") */
                                            content: counter(proposal-section) "." counter(terms-sub-section) " ";
                                        }
                                    </style>
                                    
                                    <t t-out="doc.terms_conditions"/>
                                </div>
                            </div>
                        </t>

                        <t t-if="doc.approval_block">
                            <div class="mt-4 content-block-wrapper" style="page-break-inside: avoid;">
                                <h4 class="dynamic-section" style="border-bottom: 1px solid #005580;">Approval</h4>
                                <div class="mt-2"><t t-out="doc.approval_block"/></div>
                            </div>
                        </t>
                        
                    </div>
                </t>
            </t>
        </t>
    </template>

    <record id="action_report_crm_proposal" model="ir.actions.report">
        <field name="name">Print Proposal</field>
        <field name="model">crm.proposal</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">custom_crm_proposal.report_proposal_document</field>
        <field name="report_file">custom_crm_proposal.report_proposal_document</field>
        <field name="print_report_name">'Proposal - %s' % (object.name)</field>
        <field name="binding_model_id" ref="model_crm_proposal"/>
        <field name="binding_type">report</field>
    </record>
</odoo>
