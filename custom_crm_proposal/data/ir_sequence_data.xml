<odoo>
    <data noupdate="1">
        <record id="seq_crm_proposal" model="ir.sequence">
            <field name="name">CRM Proposal Sequence</field>
            <field name="code">crm.proposal</field>
            <field name="prefix">FTP </field>
            <field name="padding">3</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
            <field name="company_id" eval="False"/>
        </record>
        <record id="paperformat_proposal_report" model="report.paperformat">
            <field name="name">Proposal Letter Format</field>
            <field name="default" eval="True" />
            <field name="format">A4</field>
            <field name="orientation">Portrait</field>
            <field name="margin_top">12</field>
            <field name="margin_bottom">15</field>
            <field name="margin_left">15</field>
            <field name="margin_right">15</field>
            <field name="header_line" eval="False" />
            <field name="header_spacing">5</field>
            <field name="dpi">96</field>
        </record>
    </data>
</odoo>