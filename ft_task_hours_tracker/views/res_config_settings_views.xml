<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>

        <record id="view_res_config_settings_ft_task_logs" model="ir.ui.view">
            <field name="name">res.config.settings.ft.task.logs.admin</field>
            <field name="model">res.config.settings</field>
            <field name="inherit_id" ref="project.res_config_settings_view_form"/>
            <field name="arch" type="xml">

  
                <xpath expr="//field[@name='module_hr_timesheet']/../.."
                       position="attributes">
                    <attribute name="groups">base.group_system</attribute>
                </xpath>

                <xpath expr="//field[@name='module_hr_timesheet']/../.."
                       position="after">
                    <div class="o_setting_box">
                        <div class="o_setting_left_pane"/>
                        <div class="o_setting_right_pane">
                            <label for="ft_default_task_time_limit"/>
                            <div class="text-muted">
                                Default maximum hours allowed per task (0 = no limit)
                            </div>
                            <div class="mt8">
                                <field name="ft_default_task_time_limit" widget="float_time"/>
                            </div>
                        </div>
                    </div>
                </xpath>

            </field>
        </record>

    </data>
</odoo>
