<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_project_form_ft_field_order" model="ir.ui.view">
        <field name="name">project.project.form.ft.field.order</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.edit_project"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='brd_approval_date']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='brd_submission_date']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
           
            <xpath expr="//field[@name='kick_start_meeting_date']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='sandbox_review_date']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='support_start_date']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='uat_start_date']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='warranty_end_date']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
             <xpath expr="//field[@name='partner_id']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
           <xpath expr="//field[@name='pm_id']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
           
            <xpath expr="//field[@name='date_start']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='go_live_date']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <xpath expr="//field[@name='user_id']" position="after">
                <field name="effective_hours" string="Actual Hours" widget="float_time" readonly="1"/>
            </xpath>
            
            <xpath expr="//group[group/field[@name='date_start']]" position="after">

                <group string="Dates">

                    <group>
                        <field name="kick_start_meeting_date"/>
                        <field name="brd_approval_date"/>
                        <field name="sandbox_review_date"/>
                        <field name="go_live_date"/>
                    </group>

                    <group>
                        <field name="uat_start_date"/>
                        <field name="support_start_date"/>
                        <field name="warranty_end_date"/>
                    </group>

                </group>

            </xpath>
        </field>
    </record>

    <record id="view_project_list_ft_hours" model="ir.ui.view">
        <field name="name">project.project.list.ft.hours</field>
        <field name="model">project.project</field>
        <field name="arch" type="xml">
            <list string="Projects" decoration-danger="ft_has_exceeded_tasks">
                <field name="name" string="Project Name"/>
                <field name="user_id" string="Project Manager" optional="show"/>
                <field name="partner_id" string="Customer" optional="show"/>
                <field name="date_start" string="Start Date" optional="show"/>
                <field name="date" string="Deadline" optional="show"/>
                <field name="allocated_hours" string="Estimated Hours" widget="float_time" optional="show"/>
                <field name="effective_hours" string="Actual Hours" widget="float_time" optional="show"/>
                <field name="ft_has_exceeded_tasks" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="view_project_form_inherit_task_fields" model="ir.ui.view">
    <field name="name">project.project.form.inherit.task.fields</field>
    <field name="model">project.project</field>
    <field name="inherit_id" ref="qa_testapp.view_project_form_inherit_qa_tabs"/>
    <field name="arch" type="xml">

        <xpath expr="//page[@name='qa_tasks']//field[@name='date_deadline']"
               position="after">
            <field name="ft_total_hours_taken"
                       string="Actual Hours"
                       widget="float_time"
                       readonly="1"/>
        </xpath>

    </field>
</record>

<record id="project_form_inherit_estimated_time" model="ir.ui.view">
    <field name="name">project.project.form.estimated.time</field>
    <field name="model">project.project</field>
    <field name="inherit_id" ref="hr_timesheet.project_invoice_form"/>
    <field name="arch" type="xml">
     <xpath expr="//field[@name='allocated_hours']" position="attributes">
            <attribute name="invisible">1</attribute>
        </xpath>

        <!-- Move Allocated Hours above Actual Hours -->
        <xpath expr="//field[@name='user_id']" position="after">
            <field name="allocated_hours"
                   string="Estimated Time"
                   widget="timesheet_uom_no_toggle"/>
        </xpath>

     

    </field>
</record>

</odoo>
