<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!-- Restrict the Gateway menu (under Discuss/Email) to Sales + Marketing -->
    <record id="mail_gateway.mail_gateway_menu" model="ir.ui.menu">
        <field
            name="groups_id"
            eval="[(6, 0, [ref('sales_team.group_sale_salesman'), ref('mass_mailing.group_mass_mailing_user')])]"
        />
    </record>

    <!-- Restrict the WhatsApp Templates action to Sales + Marketing -->
    <record id="mail_gateway_whatsapp.action_mail_whatsapp_template_gateway" model="ir.actions.act_window">
        <field
            name="groups_id"
            eval="[(6, 0, [ref('sales_team.group_sale_salesman'), ref('mass_mailing.group_mass_mailing_user')])]"
        />
    </record>

    <!-- Restrict the Message Tracking menu (inside Contacts) to Sales + Marketing -->
    <record id="ft_message_tracking.menu_ft_message_tracking" model="ir.ui.menu">
        <field
            name="groups_id"
            eval="[(6, 0, [ref('sales_team.group_sale_salesman'), ref('mass_mailing.group_mass_mailing_user')])]"
        />
    </record>
</odoo>
