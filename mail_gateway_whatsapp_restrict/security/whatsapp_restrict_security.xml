<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="mail_whatsapp_template_sales_marketing_rule" model="ir.rule">
        <field name="name">WhatsApp Template: only Sales and Marketing</field>
        <field name="model_id" ref="mail_gateway_whatsapp.model_mail_whatsapp_template" />
        <field
            name="groups"
            eval="[(4, ref('sales_team.group_sale_salesman')), (4, ref('mass_mailing.group_mass_mailing_user'))]"
        />
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="perm_read" eval="True" />
        <field name="perm_write" eval="True" />
        <field name="perm_create" eval="True" />
        <field name="perm_unlink" eval="True" />
    </record>

    <record id="ft_message_tracking_sales_marketing_rule" model="ir.rule">
        <field name="name">FT Message Tracking: only Sales and Marketing</field>
        <field name="model_id" ref="ft_message_tracking.model_ft_message_tracking" />
        <field
            name="groups"
            eval="[(4, ref('sales_team.group_sale_salesman')), (4, ref('mass_mailing.group_mass_mailing_user'))]"
        />
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="perm_read" eval="True" />
        <field name="perm_write" eval="True" />
        <field name="perm_create" eval="True" />
        <field name="perm_unlink" eval="True" />
    </record>
</odoo>
