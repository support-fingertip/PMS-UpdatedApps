<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- List View -->
    <record id="qa_testapp_view_ticket_list" model="ir.ui.view">
        <field name="name">qa_testapp.ticket.list</field>
        <field name="model">qa_testapp.ticket</field>
        <field name="arch" type="xml">
            <list decoration-danger="severity == 'blocker'"
                  decoration-warning="severity == 'critical'"
                  decoration-success="status == 'fixed'"
                  decoration-muted="status == 'closed'">
                <field name="bug_id"/>
                <field name="title"/>
                <field name="project_id"/>
                <field name="severity"/>
                <field name="priority"/>
                <field name="status"/>
                <field name="environment"/>
                <field name="device"/>
                <field name="reproducibility"/>
                <field name="reporter_id"/>
                <field name="assignee_id"/>
                <field name="reported_date"/>
            </list>
        </field>
    </record>
    <!-- Form View -->
    <record id="qa_testapp_view_ticket_form" model="ir.ui.view">
        <field name="name">qa_testapp.ticket.form</field>
        <field name="model">qa_testapp.ticket</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_in_progress" type="object" string="In Progress"
                            class="btn-primary" invisible="status in ('in_progress', 'fixed', 'closed')"/>
                    <button name="action_fixed" type="object" string="Fixed"
                            class="btn-success" invisible="status in ('open', 'fixed', 'closed')"/>
                    <button name="action_closed" type="object" string="Close"
                            class="btn-secondary" invisible="status in ('open', 'closed')"/>
                    <button name="action_reopen" type="object" string="Re-Open"
                            class="btn-warning" invisible="status not in ('fixed', 'closed')"/>
                    <field name="status" widget="statusbar" clickable="1" statusbar_visible="open,in_progress,fixed,closed,reopened"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="bug_id" readonly="1" class="text-muted"/>
                        </h1>
                        <h2>
                            <field name="title"/>
                        </h2>
                    </div>
                    <group>
                        <group string="Classification">
                            <field name="severity"/>
                            <field name="priority"/>
                            <field name="reproducibility"/>
                            <field name="environment" required="1"/>
                            <field name="device"/>
                        </group>
                        <group string="Project and Reporter">
                            <field name="project_id"/>
                            <field name="module_id"
                                   options="{'no_create': True}"
                                   domain="[('project_ids', '=', project_id)]"/>
                            <field name="reporter_id"/>
                            <field name="assignee_id"/>
                            <field name="reported_date"/>
                            <field name="test_case_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description">
                            <field name="description"/>
                        </page>
                        <page string="Steps to Reproduce">
                            <field name="steps_to_reproduce"/>
                        </page>
                        <page string="Results">
                            <group>
                                <field name="expected_result"/>
                                <field name="actual_result"/>
                            </group>
                        </page>
                        <page string="Evidence">
                            <field name="evidence_notes"/>
                            <field name="evidence_attachment_ids" widget="many2many_binary" string="Attachments"/>
                        </page>
                    </notebook>
                </sheet>
                 <chatter />
            </form>
        </field>
    </record>
    <!-- Kanban View -->
    <record id="qa_testapp_view_ticket_kanban" model="ir.ui.view">
        <field name="name">qa_testapp.ticket.kanban</field>
        <field name="model">qa_testapp.ticket</field>
        <field name="arch" type="xml">
            <kanban default_group_by="status">
                <field name="bug_id"/>
                <field name="title"/>
                <field name="severity"/>
                <field name="priority"/>
                <field name="status"/>
                <field name="reporter_id"/>
                <field name="project_id"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <strong>[<field name="bug_id"/>] <field name="title"/></strong>
                            <div><field name="severity"/> | <field name="priority"/></div>
                            <div><field name="project_id"/></div>
                            <div class="oe_kanban_bottom_left">
                                <field name="reporter_id" widget="many2one_avatar_user"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
    <record id="qa_testapp_action_ticket" model="ir.actions.act_window">
        <field name="name">Bug</field>
        <field name="res_model">qa_testapp.ticket</field>
        <field name="view_mode">list,form,kanban</field>
    </record>
    
    <!-- Action -->
    <record id="qa_testapp_action_test_plan" model="ir.actions.act_window">
        <field name="name">Test Plans</field>
        <field name="res_model">qa_testapp.test_plan</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p>No test plans found. Let's create one!</p>
        </field>
    </record>
</odoo>