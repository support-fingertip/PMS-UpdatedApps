<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- List View -->
    <record id="qa_testapp_view_test_scenario_list" model="ir.ui.view">
        <field name="name">qa_testapp.test_scenario.list</field>
        <field name="model">qa_testapp.test_scenario</field>
        <field name="arch" type="xml">
            <list string="Test Scenarios">
                <field name="date"/>
                <field name="test_scenario_id"/>
                <field name="project_id"/>
                <field name="module_id"/>
                <field name="description"/>
                <field name="status"/>
                <field name="comments"/>
                <field name="created_by"/>
            </list>
        </field>
    </record>
    <!-- Form View -->
    <record id="qa_testapp_view_test_scenario_form" model="ir.ui.view">
        <field name="name">qa_testapp.test_scenario.form</field>
        <field name="model">qa_testapp.test_scenario</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="test_scenario_id" readonly="1"/>
                            <field name="date"/>
                            <field name="project_id"/>
                            <field name="available_module_ids" invisible="1"/>
                            <field name="module_id"/>
                        </group>
                        <group>
                            <field name="status"/>
                            <field name="created_by"/>
                            <field name="reviewed_by"/>
                        </group>
                    </group>
                    <group>
                        <field name="description"/>
                    </group>
                    <group>
                        <field name="comments"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="qa_testapp_action_test_scenario" model="ir.actions.act_window">
        <field name="name">Test Scenarios</field>
        <field name="res_model">qa_testapp.test_scenario</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
