<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="seq_qa_testapp_ticket" model="ir.sequence">
            <field name="name">QA Ticket</field>
            <field name="code">qa_testapp.ticket</field>
            <field name="prefix">BUG-</field>
            <field name="padding">4</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
            <field name="company_id" eval="False"/>
        </record>
        <record id="seq_qa_testapp_test_case" model="ir.sequence">
            <field name="name">QA Test Case</field>
            <field name="code">qa_testapp.test_case</field>
            <field name="prefix">TC-</field>
            <field name="padding">4</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
            <field name="company_id" eval="False"/>
        </record>
        <record id="seq_qa_testapp_test_scenario" model="ir.sequence">
            <field name="name">QA Test Scenario</field>
            <field name="code">qa_testapp.test_scenario</field>
            <field name="prefix">TS-</field>
            <field name="padding">4</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
            <field name="company_id" eval="False"/>
        </record>
    </data>
</odoo>