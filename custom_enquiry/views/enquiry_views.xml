<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List View -->
    <record id="view_x_enquiry_list" model="ir.ui.view">
        <field name="name">x.enquiry.list</field>
        <field name="model">x.enquiry</field>
        <field name="arch" type="xml">
            <list string="Enquiries">
                <field name="x_name"/>
                <field name="x_email"/>
                <field name="x_phone"/>
                <field name="x_company"/>
                <field name="x_subject"/>
                <field name="create_date"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_x_enquiry_form" model="ir.ui.view">
        <field name="name">x.enquiry.form</field>
        <field name="model">x.enquiry</field>
        <field name="arch" type="xml">
            <form string="Enquiry">
                <sheet>
                    <group>
                        <field name="x_name"/>
                        <field name="x_email"/>
                        <field name="x_phone"/>
                        <field name="x_company"/>
                        <field name="x_subject"/>
                    </group>
                    <group>
                        <field name="x_message"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_x_enquiry" model="ir.actions.act_window">
        <field name="name">Enquiries</field>
        <field name="res_model">x.enquiry</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menu -->
    <menuitem id="menu_x_enquiry_root"
              name="Enquiries"
              sequence="90"/>

    <menuitem id="menu_x_enquiry"
              name="All Enquiries"
              parent="menu_x_enquiry_root"
              action="action_x_enquiry"/>

</odoo>